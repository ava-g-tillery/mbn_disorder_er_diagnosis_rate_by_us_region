#Create Table of Means and Error
  summary <- MBNDiagnosis %>% group_by(USRegion) %>%
    summarise(
      meanvisits = mean(Rate),
      sdvisits = sd(Rate),
      n = n(),  # Number of observations
      sevisits= sdvisits / sqrt(n),  # Standard Error
      se2= sevisits*2
    )
#Create Bar Graph
  summary_df <- summary
  ggplot(summary_df,
         aes(x = USRegion,
             y = meanvisits,
             fill = USRegion)) +
    geom_col() +
    geom_errorbar(aes(ymin = meanvisits - se2,
                      ymax = meanvisits + se2),
                  width = 0.2,
                  color = "black") +
    scale_fill_manual(values = c(
      Midwest = "#F8766D",
      Northeast = "#7CAE00",
      South = "#00BFC4",
      West = "#C77CFF"
    )) +
    scale_y_continuous(n.breaks = 8) +
    theme_bw() +
    labs(
      title = "Average Annual ER Diagnosis Rate for MBN Disorders",
      subtitle = "by United States Region between 2016 and 2022",
      x = "U.S. Region",
      y = "Diagnosis Rate (per 1,000 Civilians)"
    ) +
    theme(legend.position = "none")
